// Test file I/O wrappers using syscalls

extern fn open(path: ptr, flags: int, mode: int): int
extern fn write(fd: int, buf: ptr, len: int): int
extern fn read(fd: int, buf: ptr, len: int): int
extern fn close(fd: int): int
extern fn malloc(sz: int): ptr
extern fn free(p: ptr): int

fn main() {
    let path = "build/tmp_io.txt"
    let content = "hello, io"
    
    let fd = open(path, 65, 420)
    if (fd < 0) { return 1 }
    write(fd, content, 9)
    close(fd)

    let fd2 = open(path, 0, 0)
    if (fd2 < 0) { return 2 }
    
    let buf = malloc(64)
    read(fd2, buf, 64)
    
    write(1, buf, 9)
    write(1, "\n", 1)
    
    close(fd2)
    free(buf)
    return 0
}
