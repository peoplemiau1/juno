fn main() {
    output("=== JUNO v1.0 TEST ===")

    a = 20
    b = 4
    sum = a + b
    diff = a - b
    prod = a * b
    quot = a / b

    output("20 + 4 =")
    output_int(sum)
    output("20 - 4 =")
    output_int(diff)
    output("20 * 4 =")
    output_int(prod)
    output("20 / 4 =")
    output_int(quot)

    output("While loop 3 to 1:")
    count = 3
    while (count != 0) {
        output_int(count)
        count--
    }

    output("For loop 1 to 3:")
    for (i = 1; i < 4; i++) {
        output_int(i)
    }

    output("=== ALL TESTS PASSED ===")
}
