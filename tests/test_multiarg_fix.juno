fn add(a, b) {
    return a + b
}

fn multiply(x, y) {
    return x * y
}

fn main() {
    let result1 = add(100, 200)
    print("add(100, 200) = ")
    print(result1)

    let result2 = multiply(15, 20)
    print("multiply(15, 20) = ")
    print(result2)

    let result3 = add(add(10, 20), add(30, 40))
    print("add(add(10,20), add(30,40)) = ")
    print(result3)

    return result1
}
