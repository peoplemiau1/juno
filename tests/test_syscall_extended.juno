fn main() {

    let addr = syscall(9, 0, 4096, 3, 34, 0 - 1, 0)

    if (addr > 0) {
        prints("mmap success")

        *addr = 42
        if (*addr == 42) {
            prints("memory write/read success")
        }

        syscall(11, addr, 4096)
        prints("munmap success")
    } else {
        prints("mmap failed")
    }

    return 0
}
