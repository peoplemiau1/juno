fn swap(a, b) {
    let tmp = *a
    *a = *b
    *b = tmp
}

fn main() {
    let x = 10
    let ptr = &x
    let val = *ptr

    *ptr = 42
    let x2 = x

    let a = 100
    let b = 200
    swap(&a, &b)

    let arr[3]
    arr[0] = 5
    arr[1] = 10
    arr[2] = 15

    let p = &arr[1]
    let elem = *p

    return val + x2 + a + b + elem
}
