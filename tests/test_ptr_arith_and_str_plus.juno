// Pointer arithmetic test

fn main() {
    let arr[3]
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3

    // In Juno, 'arr' is already a pointer to the start of the array
    let p = arr 
    let p1 = p + 1
    let p0 = p 
    
    let v1 = *p1 // Should be 2
    let v0 = *p0 // Should be 1
    let v = v1 + v0 // 3

    if (v == 3) {
        return 0
    }
    return 1
}
