fn double(x) {
    return x * 2
}

fn main() {
    println("=== JUNO MATH & STDLIB TEST ===")

    let val = 5
    println("double(5) =")
    output_int(double(val))

    println("square(5) =")
    output_int(square(val))

    println("factorial(5) =")
    output_int(factorial(val))

    return 0
}
