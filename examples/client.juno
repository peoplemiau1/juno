fn main() {
    print("Connecting to localhost:8080...")

    let sock = socket()

    connect(sock, ip(127, 0, 0, 1), 8080)

    print("Connected! Sending message...")

    send(sock, "Hello from Juno!")

    let buf[128]

    let n = recv(sock, buf, 128)

    print("Received response!")

    close(sock)

    return 0
}
