#!/usr/bin/env ruby
require 'optparse'
require 'fileutils'

PROJECT_ROOT = File.expand_path("..", File.dirname(__FILE__))

GREEN = "\e[32m"
BOLD = "\e[1m"
RESET = "\e[0m"
RED = "\e[31m"

def run_tool(tool, args)
  tool_path = File.join(PROJECT_ROOT, "tools", "#{tool}.juno")
  compiler_path = File.join(PROJECT_ROOT, "bin", "juno")
  system("JUNO_NO_AUDIT=1 #{compiler_path} -r #{tool_path} #{args.join(' ')}")
end

case ARGV[0]
when "fmt"
  file = ARGV[1]
  if file && File.exist?(file)
    system("ruby #{File.join(PROJECT_ROOT, 'tools', 'jfmt.rb')} #{file}")
    exit 0
  end
  puts "Usage: juno fmt <file>"
  exit 1
when "disasm"
  file = ARGV[1]
  if file && File.exist?(file)
    system("objdump -d #{file} | head -n 50")
    exit 0
  end
  puts "Usage: juno disasm <binary>"
  exit 1
when "hex"
  file = ARGV[1]
  if file && File.exist?(file)
    system("hexdump -C #{file} | head -n 50")
    exit 0
  end
  puts "Usage: juno hex <binary>"
  exit 1
when "-h", "--help", "help"
  puts <<~HELP
    #{BOLD}Juno Language Toolchain#{RESET}
    #{BOLD}Usage:#{RESET} juno [command] [options] <input_file>

    #{BOLD}Commands:#{RESET}
      fmt <file>        Format Juno source code
      disasm <bin>      Disassemble binary (objdump)
      hex <bin>         Show hex dump (hexdump)
      help              Show this help

    #{BOLD}Options:#{RESET}
      -a, --arch ARCH   Target architecture:
                        #{GREEN}x86_64, aarch64, arm, riscv32, riscv64#{RESET} (default: x86_64)
      -t, --target TYPE Compilation target:
                        #{GREEN}exe, flat, obj#{RESET} (default: exe)
      -o, --output FILE Specify output binary path
      -O, --opt LEVEL   Optimization level (0, 1, 2, 3) (default: 2)
      -r, --run         Execute the binary after successful compilation
      --asm             Dump generated LLVM/Assembly to log
      --no-audit        Disable resource safety auditing
      --native          Enable experimental native backend (non-LLVM)

    #{BOLD}Examples:#{RESET}
      juno main.juno                         # Compile for host
      juno -O3 main.juno                      # Compile with max optimization
      juno -a aarch64 -t flat kernel.juno    # Compile raw ARM binary
      juno -r tests/test_simple.juno         # Compile and run
  HELP
  exit 0
end
    
    require_relative "../src/juno/compiler"
    
    options = { arch: :x86_64, os: :linux, output: nil, run: false, show_asm: false, target: :exe, opt_level: 2 }
    begin
      parser = OptionParser.new do |opts|
        opts.on("-a", "--arch ARCH", [:x86_64, :aarch64, :arm, :riscv32, :riscv64]) { |a| options[:arch] = a }
        opts.on("-t", "--target TARGET", [:exe, :flat, :obj]) { |t| options[:target] = t }
        opts.on("-O", "--opt LEVEL", Integer) { |o| options[:opt_level] = o }
        opts.on("-o", "--output FILE") { |o| options[:output] = o }
        opts.on("-r", "--run") { options[:run] = true }
        opts.on("--asm") { options[:show_asm] = true }
        opts.on("--no-audit") { options[:no_audit] = true }
        opts.on("--native") { options[:native] = true }
      end
    
      parser.parse!
    rescue OptionParser::ParseError => e
      puts "#{RED}#{BOLD}error#{RESET}: #{e.message}"
      puts "Run 'juno --help' for usage information."
      exit 1
    end
    
    input_file = ARGV[0]
    if !input_file
      puts "#{RED}#{BOLD}error#{RESET}: no input file specified"
      puts "Usage: juno [options] <input_file>"
      exit 1
    end
    
    if !File.exist?(input_file)
      puts "#{RED}#{BOLD}error#{RESET}: file not found: #{input_file}"
      exit 1
    end
    
    output_path = options[:output] || File.join(PROJECT_ROOT, "build", "output")
    FileUtils.mkdir_p(File.dirname(output_path))
    
    begin
      puts "   #{GREEN}#{BOLD}Compiling#{RESET} #{input_file} (#{options[:arch]} -> #{options[:target]})"
    
      stdlib_path = ENV['JUNO_STDLIB'] || File.join(PROJECT_ROOT, "stdlib")
    
      compiler = Juno::Compiler.new(
        arch: options[:arch], 
        os: options[:os], 
        output: output_path, 
        audit: !options[:no_audit],
        native: options[:native],
        target: options[:target],
        opt_level: options[:opt_level],
        stdlib_path: stdlib_path
      )
    
      compiler.compile(input_file)
      
      puts "    #{GREEN}#{BOLD}Finished#{RESET} #{options[:target]} output at #{output_path}"
    
      if options[:show_asm]
        puts "\n#{BOLD}Generated Log (#{options[:arch]}):#{RESET}"
        puts (compiler.asm_log || ["No log generated."]).join("\n")
      end
    
      if options[:run]
        if options[:target] != :exe
          puts "#{RED}#{BOLD}warning#{RESET}: cannot run non-executable target: #{options[:target]}"
        else
          puts "     #{GREEN}#{BOLD}Running#{RESET} #{output_path}..."
          exec(output_path)
        end
      end
    rescue => e
      puts "\n#{RED}#{BOLD}error#{RESET}: #{e.message}"
      # Only show backtrace for internal compiler errors, not user/cli errors
      if e.message.include?("Linker") || e.message.include?("failed")
        # Keep it clean
      else
        puts e.backtrace.join("\n") if ENV['JUNO_DEBUG']
      end
      exit 1
    end
