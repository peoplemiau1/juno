#!/usr/bin/env ruby
# Juno Language CLI - Minimalist GCC/Cargo style

require 'optparse'
require 'fileutils'
require_relative "../src/compiler"

# Colors for CLI
GREEN = "\e[32m"
BOLD = "\e[1m"
RESET = "\e[0m"
RED = "\e[31m"

options = {
  arch: :x86_64,
  os: :linux,
  output: nil,
  run: false
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: juno [options] <input_file>"
  opts.on("-a", "--arch ARCH", [:x86_64, :aarch64], "Target architecture (x86_64, aarch64)") { |a| options[:arch] = a }
  opts.on("-o", "--output FILE", "Output binary path") { |o| options[:output] = o }
  opts.on("-t", "--target OS", [:linux, :flat], "Target OS (linux, flat)") { |t| options[:os] = t }
  opts.on("-r", "--run", "Run after compilation") { options[:run] = true }
end

parser.parse!

if ARGV.empty?
  puts parser
  exit
end

input_file = ARGV[0]
output_path = options[:output] || "build/output"
FileUtils.mkdir_p("build")

begin
  puts "   #{GREEN}#{BOLD}Compiling#{RESET} #{input_file} (#{options[:arch]})"
  
  compiler = Juno::Compiler.new(
    arch: options[:arch],
    os: options[:os],
    output: output_path
  )
  
  start_time = Time.now
  final_output = compiler.compile(input_file)
  elapsed = (Time.now - start_time).round(2)

  puts "    #{GREEN}#{BOLD}Finished#{RESET} in #{elapsed}s"

  if options[:run] && options[:os] == :linux
    puts "     #{GREEN}#{BOLD}Running#{RESET} `./#{final_output}`"
    exec("./#{final_output}")
  end

rescue JunoError => e
  e.display
  exit 1
rescue Interrupt
  puts "\nAborted."
  exit 1
rescue => e
  puts "\n#{RED}#{BOLD}internal error#{RESET}: #{e.message}"
  exit 1
end
