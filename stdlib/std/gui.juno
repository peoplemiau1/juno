struct CssProvider {
    handle: ptr
}

fn CssProvider.new(): CssProvider {
    let self: CssProvider = malloc(sizeof(CssProvider))
    self.handle = gtk_css_provider_new()
    return self
}

fn CssProvider.load(self, css_data: ptr) {
    let length = strlen(css_data)
    gtk_css_provider_load_from_data(self.handle, css_data, length, 0)
}

fn CssProvider.apply_to_widget(self, widget_ptr: ptr) {
    let context = gtk_widget_get_style_context(widget_ptr)
    gtk_style_context_add_provider(context, self.handle, 800)
}
