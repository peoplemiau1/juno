fn glib_list_append(head: ptr, str: ptr): ptr {
    return g_slist_append(head, str)
}

struct GulkanApp {
    window: ptr
    client: ptr
    surface: ptr
}

fn create_gulkan_app(width: int, height: int, title: ptr): GulkanApp {
    let self: GulkanApp = malloc(sizeof(GulkanApp))
    self.window = 0
    self.client = 0
    self.surface = 0

    prints("DEBUG: Calling glfwInit...\n")
    if (glfwInit() == 0) {
        prints("ERROR: glfwInit failed!\n")
        free(self)
        return 0
    }

    prints("DEBUG: Calling glfwCreateWindow...\n")
    glfwWindowHint(0x00022001, 0)
    self.window = glfwCreateWindow(width, height, title, 0, 0)
    
    if (self.window == 0) {
        prints("ERROR: glfwCreateWindow failed!\n")
        return 0
    }

    prints("DEBUG: Collecting Vulkan extensions...\n")
    let mut count = 0
    let ext_arr = glfwGetRequiredInstanceExtensions(&count)
    
    prints("DEBUG: Extensions count found: ")
    print(count)
    prints("\n")

    let mut instance_ext_list = 0
    let mut i = 0
    while (i < count) {
        let ext = *(ptr_add(ext_arr, i))
        prints("DEBUG: Enabling extension: ")
        prints(ext)
        prints("\n")
        instance_ext_list = glib_list_append(instance_ext_list, ext)
        i = i + 1
    }

    let mut device_ext_list = 0
    device_ext_list = glib_list_append(device_ext_list, "VK_KHR_swapchain")

    prints("DEBUG: Calling gulkan_client_new_from_extensions...\n")
    self.client = gulkan_client_new_from_extensions(instance_ext_list, device_ext_list)
    
    g_slist_free(instance_ext_list)
    g_slist_free(device_ext_list)

    if (self.client == 0) {
        prints("ERROR: gulkan_client_new_from_extensions failed!\n")
        return 0
    }

    prints("DEBUG: Calling glfwCreateWindowSurface...\n")
    let vk_instance = gulkan_client_get_instance_handle(self.client)
    let mut surface = 0
    let res = glfwCreateWindowSurface(vk_instance, self.window, 0, &surface)
    
    if (res != 0) {
        prints("ERROR: glfwCreateWindowSurface failed! VkResult code: ")
        print(res)
        prints("\n")
        return 0
    }
    self.surface = surface

    prints("DEBUG: GulkanApp init SUCCESS!\n")
    return self
}

fn GulkanApp.run(self) {
    while (glfwWindowShouldClose(self.window) == 0) {
        glfwPollEvents()
    }
}

fn GulkanApp.destroy(self) {
    if (self.client != 0) {
        g_object_unref(self.client)
    }

    if (self.window != 0) {
        glfwDestroyWindow(self.window)
        glfwTerminate()
    }

    free(self)
}

fn default_destroy_callback() {
    gtk_main_quit()
}

struct GuiApp {
    initialized: int
}

fn GuiApp.init(): GuiApp {
    let self: GuiApp = malloc(sizeof(GuiApp))
    let mut argc = 1
    let argv = malloc(16)
    *argv = "doger"
    *(ptr_add(argv, 1)) = 0
    let mut p_argv = argv
    gtk_init(&argc, &p_argv)
    self.initialized = 1
    return self
}

fn GuiApp.run(self) {
    gtk_main()
}

fn GuiApp.quit(self) {
    gtk_main_quit()
}

struct Window {
    handle: ptr
}

fn Window.new(title: ptr, width: int, height: int): Window {
    let self: Window = malloc(sizeof(Window))
    self.handle = gtk_window_new(0)
    gtk_window_set_title(self.handle, title)
    gtk_window_set_default_size(self.handle, width, height)
    g_signal_connect_data(self.handle, "destroy", default_destroy_callback, 0, 0, 0)
    return self
}

fn Window.set_resizable(self, yes_no: int) {
    gtk_window_set_resizable(self.handle, yes_no)
}

fn Window.set_keep_above(self, yes_no: int) {
    gtk_window_set_keep_above(self.handle, yes_no)
}

fn Window.set_decorated(self, yes_no: int) {
    gtk_window_set_decorated(self.handle, yes_no)
}

fn Window.maximize(self) {
    gtk_window_maximize(self.handle)
}

fn Window.minimize(self) {
    gtk_window_iconify(self.handle)
}

fn Window.add(self, widget_ptr: ptr) {
    gtk_container_add(self.handle, widget_ptr)
}

fn Window.show(self) {
    gtk_widget_show_all(self.handle)
}

fn Window.on_destroy(self, callback_ptr: ptr) {
    g_signal_connect_data(self.handle, "destroy", callback_ptr, 0, 0, 0)
}

