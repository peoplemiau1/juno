extern fn pthread_create(thread_ptr, attr_ptr, start_routine, arg_ptr)
extern fn pthread_join(thread_id, retval_ptr)
extern fn pthread_exit(retval_ptr)

fn thread_spawn(f, arg) {
    let thread_ptr = malloc(8)
    pthread_create(thread_ptr, 0, f, arg)
    return thread_ptr
}

fn thread_join(thread_ptr) {
    let tid = *thread_ptr
    pthread_join(tid, 0)
    free(thread_ptr)
    return 0
}

fn thread_exit() {
    pthread_exit(0)
}
